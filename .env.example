# Firebase Configuration (Client-side — used by Vite)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# API Base URL
# For local development with Netlify CLI (netlify dev):
VITE_API_BASE_URL=http://localhost:8888/.netlify/functions
# For production (leave empty — defaults to /.netlify/functions):
# VITE_API_BASE_URL=

# Firebase Admin (for serverless functions)
# Option A: Full service account JSON (preferred for production):
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","client_email":"...","private_key":"..."}
#
# Option B: Individual env vars (easier for local dev):
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Telegram Bot (for alert notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Transport for NSW API (get from https://opendata.transport.nsw.gov.au)
TFN_API_KEY=your-tfnsw-api-key
